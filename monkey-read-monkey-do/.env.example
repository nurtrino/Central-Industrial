# Monkey Read Monkey Do credentials — copy to ".env" and fill in.
# This file stays on your machine. Audio NEVER uses these; only the text
# transcript is sent to the notes LLM.

# HuggingFace token (free) for pyannote speaker diarization.
# 1) create account at huggingface.co
# 2) accept the license at huggingface.co/pyannote/speaker-diarization-3.1
#    and huggingface.co/pyannote/segmentation-3.0
# 3) make a token at huggingface.co/settings/tokens  (read scope is enough)
HF_TOKEN=

# Anthropic API key for the notes step (transcript text only).
ANTHROPIC_API_KEY=

# Optional overrides:
# NOTEMAX_WHISPER_MODEL=large-v3
# NOTEMAX_MODEL=claude-opus-4-8

# NOTEMAX_OFFLINE=1 forces the local audio stage (Whisper + diarization) fully
# offline — no HuggingFace network calls at all while audio is processed. Requires
# the models to have been downloaded/cached once. Belt-and-suspenders privacy.
NOTEMAX_OFFLINE=0
