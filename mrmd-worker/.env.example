# Monkey Read Monkey Do — GPU worker config. Copy to ".env" and fill in.

# Shared secret the hosted UI must send (Authorization: Bearer <token> or X-Worker-Token).
# REQUIRED — the worker refuses all jobs if this is unset. Use a long random string,
# and set the SAME value as MRMD_WORKER_TOKEN on the hosted UI (Render).
MRMD_WORKER_TOKEN=

# CORS: the exact origin of the hosted UI so the browser may POST audio here.
# e.g. https://monkey-read-monkey-do.onrender.com  (use * only for local testing)
MRMD_ALLOWED_ORIGIN=*

# HuggingFace token for pyannote speaker diarization (accept the model licenses on HF).
HF_TOKEN=

# Optional: force a Whisper model. If unset, one is auto-picked to fit your GPU's VRAM
# (>=12GB large-v3, >=8GB medium, >=5GB small, >=3GB base, else tiny).
# NOTEMAX_WHISPER_MODEL=

# Optional: fully offline audio stage (cached HF models only; no network).
# NOTEMAX_OFFLINE=0

# Optional: listen port (default 5007) and max upload size in MB (default 4096).
# PORT=5007
# MRMD_MAX_UPLOAD_MB=4096
