# Deep Research — environment variables.
# Local: copy to ".env" and fill in. Render: set these in the service's Environment tab
# (do NOT commit a real .env). The server also reads real OS env vars directly.

# ── Required ─────────────────────────────────────────────────────────────────
# Claude API key — planning, search agent, per-page extraction, synthesis.
ANTHROPIC_API_KEY=

# ── Deployment / browser mode ────────────────────────────────────────────────
# 1 = visible Chrome (local desktop). 0 = headless (Render/containers). The
# Dockerfile sets these for you; only set them for a local run if you want headless.
DRT_HEADED=1
# "chrome" = use locally installed Google Chrome; "" = Playwright's bundled Chromium.
DRT_BROWSER_CHANNEL=chrome

# ── Optional integrations ────────────────────────────────────────────────────
# Exa neural search (only active when DRT_EXA=1 and a key is set)
DRT_EXA=0
EXA_API_KEY=
# Firecrawl sub-tool
FIRECRAWL_API_KEY=
# Alternate Odysseus search providers
BRAVE_API_KEY=
TAVILY_API_KEY=

# ── Optional overrides ───────────────────────────────────────────────────────
# Where "Save & open in Word" writes .docx (defaults to ./reports beside the app).
# DRT_REPORTS_DIR=
# Bind host (defaults to 0.0.0.0). PORT is injected by Render.
# HOST=0.0.0.0
